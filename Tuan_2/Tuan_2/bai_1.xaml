<Window x:Class="Tuan_2.bai_1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_2"
        mc:Ignorable="d"
        Title="bai_1" Height="450" Width="800"
        Closing="Window_Closing">

    <Window.Resources>
            <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Width" Value="120"></Setter>
            <Setter Property="Height" Value="45"></Setter>
            <Setter Property="Padding" Value="10"></Setter>
            <Setter Property="Margin" Value="20,0,0,0"></Setter>
            <Setter Property="Background" Value="LightGray"></Setter>
            <Setter Property="BorderBrush" Value="Blue"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" RenderTransformOrigin="1.079,0.922">
        <Grid.RowDefinitions>
            <RowDefinition Height="69*"></RowDefinition>
            <RowDefinition Height="325*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock 
                   FontFamily="Times New Roman" 
                   FontSize="35" 
                   FontWeight="Bold"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Center" Height="49" Width="148" RenderTransformOrigin="0.668,0.535" Margin="0,22,0,0" Grid.RowSpan="2"
                   >
            Thông tin
        </TextBlock>

        <Border Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="12"
                Background="LightSkyBlue" Margin="0,7,0,0"
                >
        </Border>

        <StackPanel Margin="37,27,25,229" Grid.Row="1" Orientation="Horizontal">
            <TextBlock FontFamily="Times New Roman" 
                       FontSize="22" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" UseLayoutRounding="False" Margin="20,0,0,0">
                Nhập họ tên:
            </TextBlock>

            <TextBox x:Name="txtName" 
                     Width="341" 
                     Margin="20,0,0,0"
                     LostFocus="txtName_LostFocus"/>

            <TextBlock x:Name="txtNameError" 
                       Width="158" 
                       Margin="20,0,20,0"
                       Foreground="Red"
                       FontStyle="Italic"/>

        </StackPanel>

        <StackPanel Margin="37,121,25,135" Grid.Row="1" Orientation="Horizontal">
            <TextBlock FontFamily="Times New Roman" 
               FontSize="22" 
               FontWeight="Bold"
               VerticalAlignment="Center" UseLayoutRounding="False" Margin="20,0,0,0" Width="125">
              Năm sinh:
            </TextBlock>

            <TextBox x:Name="txtYear"
                     Width="340"
                     Margin="20,0,0,0"
                     LostFocus="txtYear_LostFocus"/>

            <TextBlock x:Name="txtYearError"
                       Width="158"
                       Margin="20,0,20,0"
                       Foreground="Red"
                       FontStyle="Italic"/>

        </StackPanel>

        <StackPanel Margin="168,195,152,61" Grid.Row="1" Orientation="Horizontal" Height="69">
            <Button Content="Hiển thị" 
                    Style="{StaticResource MainButton}" 
                    FontFamily="Times New Roman" 
                    FontSize="22" 
                    FontWeight="Bold"
                    Click="btnShow_Click"/>


            <Button Content="Xóa" 
                    Style="{StaticResource MainButton}" 
                    FontFamily="Times New Roman" 
                    FontSize="22" 
                    FontWeight="Bold"
                    Click="btnClear_Click"/>


            <Button Content="Thoát" 
                    Style="{StaticResource MainButton}" 
                    FontFamily="Times New Roman" 
                    FontWeight="Bold" 
                    FontSize="22"
                    Click="btnExit_Click"/>

        </StackPanel>

    </Grid>
</Window>
