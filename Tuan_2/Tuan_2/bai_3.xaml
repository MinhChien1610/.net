<Window x:Class="Tuan_2.bai_3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_2"
        mc:Ignorable="d"
        Title="bai_3" Height="600" Width="800">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="120"></Setter>
            <Setter Property="Height" Value="60"></Setter>
            <Setter Property="Padding" Value="5"></Setter>
            <Setter Property="Margin" Value="10,0,0,0"></Setter>
            <Setter Property="Background" Value="LightGray"></Setter>
            <Setter Property="BorderBrush" Value="Blue"></Setter>
            <Setter Property="Foreground" Value="Black"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="FontSize" Value="18"></Setter>
        </Style>

        <Style x:Key="SecondButton" TargetType="Button">
            <Setter Property="Width" Value="138"></Setter>
            <Setter Property="Height" Value="54"></Setter>
            <Setter Property="FontSize" Value="18"></Setter>
            <Setter Property="Background" Value="LightGray"></Setter>
            <Setter Property="Margin" Value="15,0,0,0"></Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64*"></RowDefinition>
            <RowDefinition Height="325*"></RowDefinition>
            <RowDefinition Height="87*"></RowDefinition>
            <RowDefinition Height="108*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Margin="0,15,0,0" 
                   FontFamily="Times New Roman" 
                   FontWeight="Bold" 
                   FontSize="34" 
                   Foreground="#FFF69800"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Center" Width="180" Height="39">
            MÀN ẢNH
        </TextBlock>

        <Border Grid.Row="1"
                Background="LightSlateGray"
                CornerRadius="12"
                Margin="10,10,10,10">

            <Grid Margin="20,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0"
                        Grid.Column="0"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">1
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="0"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">6
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="0"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">11
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="1"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">2
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="1"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">7
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="2"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">8
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">3
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="3"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">4
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="3"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">9
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="3"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">14
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="4"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">5
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="4"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">15
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="4"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">10
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="2"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">13
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="1"
                        Style="{DynamicResource PrimaryButton}" Click="Seat_Click" Tag="Empty">12
                </Button>

            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   FontSize="18"
                   FontWeight="Bold" Margin="166,24,500,33">
            Thành Tiền:
        </TextBlock>

        <TextBox Grid.Row="2" 
                 Margin="287,14,199,23"
                 x:Name="txt_Money"
                 IsReadOnly="True"/>

        <StackPanel Grid.Row="2" Margin="186,87,137,37" Orientation="Horizontal" Grid.RowSpan="2">
            <Button Style="{DynamicResource ResourceKey=SecondButton}"
                    Click="btnClick_Chon">
                Chọn
            </Button>
            <Button Style="{DynamicResource ResourceKey=SecondButton}"
                    Click="btnClick_Huy">
                Hủy bỏ
            </Button>
            <Button Style="{DynamicResource ResourceKey=SecondButton}"
                    Click="btnClick_End">
                Kết thúc
            </Button>
        </StackPanel>
    </Grid>
</Window>
