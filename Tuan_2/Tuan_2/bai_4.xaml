<Window x:Class="Tuan_2.bai_4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_2"
        mc:Ignorable="d"
        Title="bai_4" Height="600" Width="800">

    <Window.Resources>
        <Style x:Key="RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="22"></Setter>
            <Setter Property="FontFamily" Value="Times New Roman"></Setter>
            <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
            <Setter Property="GroupName" Value="LoaiPT"></Setter>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="228"></Setter>
            <Setter Property="Height" Value="42"></Setter>
            <Setter Property="Background" Value="White"></Setter>
            <Setter Property="Margin" Value="15,5,10,5"></Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="200"></Setter>
            <Setter Property="Height" Value="50"></Setter>
            <Setter Property="Margin" Value="15,5,10,5"></Setter>
            <Setter Property="FontFamily" Value="Times New Roman"></Setter>
            <Setter Property="FontSize" Value="22"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
        </Style>
    </Window.Resources>


    <Grid Background="#FFD4F4FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="57*"></RowDefinition>
            <RowDefinition Height="125*"></RowDefinition>
            <RowDefinition Height="402*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock
                   FontFamily="Times New Roman"
                   FontSize="38"
                   Foreground="Red"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" Height="43" Width="400">
            GIẢI PHƯƠNG TRÌNH
        </TextBlock>
        <Border Grid.Row="1"
                Background="#FFD4F4FF"
                BorderBrush="#D6DADF"
                BorderThickness="2"
                Margin="10,10,10,10"
                CornerRadius="12">
        </Border>

        <TextBlock
                   Panel.ZIndex="10"
                   FontFamily="Times New Roman"
                   FontSize="22"
                   Text="Chọn loại phương trình"
                   Background="#FFD4F4FF"
                   VerticalAlignment="Top" 
                   Margin="71,51,494,0" 
                   RenderTransformOrigin="0.5,0.5" Height="25" Grid.RowSpan="2"/>

        <RadioButton Style="{DynamicResource RadioButton}"
                     x:Name="ptBac1"
                     Content="Phương trình bậc nhất (ax + b = 0)" 
                     Margin="131,25,319,60" 
                     IsChecked="True"
                     Checked="Check_LoaiPT"
                     Grid.Row="1">
        </RadioButton>

        <RadioButton Style="{DynamicResource RadioButton}"
                     x:Name="ptBac2"
                     Content="Phương trình bậc hai (ax² + bx + c = 0)" 
                     Margin="131,60,283,18"
                     Checked="Check_LoaiPT"
                     Grid.Row="1">
        </RadioButton>

        <Border Grid.Row="1"
                CornerRadius="12"
                Margin="10,124,10,10"
                BorderBrush="#D6DADF"
                BorderThickness="2"
                Background="#FFECF3F6" Grid.RowSpan="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="71*"></RowDefinition>
                    <RowDefinition Height="71*"></RowDefinition>
                    <RowDefinition Height="71*"></RowDefinition>
                    <RowDefinition Height="181*"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock FontFamily="Times New Roman"
                           FontSize="22" Margin="24,0,107,0"
                           VerticalAlignment="Center" Height="26">
                    Hệ số a:
                </TextBlock>

                <TextBlock FontFamily="Times New Roman"
                           FontSize="22" Margin="23,0,107,0"
                           VerticalAlignment="Center" Grid.Row="1" Height="25">
                    Hệ số b:
                </TextBlock>

                <TextBlock FontFamily="Times New Roman"
                           FontSize="22" Margin="23,15,107,0"
                           VerticalAlignment="Top" Grid.Row="2" Height="25">
                    Hệ số c:
                </TextBlock>

                <TextBlock FontFamily="Times New Roman"
                           FontSize="22" Margin="23,7,107,0"
                           VerticalAlignment="Top" Grid.Row="3" Height="25">
                    Kết quả:
                </TextBlock>

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         x:Name="txt_hesoA"
                         TextChanged="Input_TextChanged"
                         Style="{DynamicResource TextBoxStyle}">
                </TextBox>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         x:Name="txt_hesoB"
                         TextChanged="Input_TextChanged"
                         Style="{DynamicResource TextBoxStyle}">
                </TextBox>

                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         x:Name="txt_hesoC"
                         TextChanged="Input_TextChanged"
                         Style="{DynamicResource TextBoxStyle}">
                </TextBox>

                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         x:Name="txt_hesoKQ"
                         Style="{DynamicResource TextBoxStyle}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="160">
                </TextBox>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        x:Name="btn_Giai"
                        Style="{DynamicResource PrimaryButton}"
                        Content="Giải"
                        Background="#FFFFF6F6"
                        IsEnabled="False"
                        Click="btnClick_Giai">
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="2"
                        x:Name="btn_Thoat"
                        Style="{DynamicResource PrimaryButton}"
                        Content="Thoát"
                        Background="Gray"
                        Click="btnClick_Thoat">
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
