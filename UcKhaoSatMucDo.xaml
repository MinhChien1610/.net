<UserControl x:Class="Tuan_7.Views.UcKhaoSatMucDo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             Background="#F1F5F9"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">


    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="110"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnswerBoxStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#BBF7D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#F0FDF4"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Khảo sát mức độ hài lòng"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Thu thập ý kiến khách hàng để cải thiện chất lượng dịch vụ"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#64748B"/>
                </StackPanel>

                <!-- THÔNG TIN KHÁCH -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Khách hàng"
                                   Foreground="#64748B"
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding TenKhachHang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Số điện thoại"
                                   Foreground="#64748B"
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SoDienThoai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Email"
                                   Foreground="#64748B"
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- NỘI DUNG CHÍNH -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Câu hỏi -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Câu hỏi 1"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="#1E293B"/>

                            <TextBlock Text="Bạn đánh giá chất lượng dịch vụ như thế nào?"
                                       Margin="0,10,0,16"
                                       TextWrapping="Wrap"
                                       Foreground="#334155"
                                       FontSize="14"/>

                            <RadioButton Content="Rất hài lòng"
                                         Margin="0,6"
                                         GroupName="MucDoHaiLong"
                                         IsChecked="{Binding IsRatHaiLong, Mode=TwoWay}"/>

                            <RadioButton Content="Hài lòng"
                                         Margin="0,6"
                                         GroupName="MucDoHaiLong"
                                         IsChecked="{Binding IsHaiLong, Mode=TwoWay}"/>

                            <RadioButton Content="Bình thường"
                                         Margin="0,6"
                                         GroupName="MucDoHaiLong"
                                         IsChecked="{Binding IsBinhThuong, Mode=TwoWay}"/>

                            <RadioButton Content="Không hài lòng"
                                         Margin="0,6"
                                         GroupName="MucDoHaiLong"
                                         IsChecked="{Binding IsKhongHaiLong, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- Danh sách phản hồi -->
                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Danh sách phản hồi"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,14"/>

                            <ItemsControl ItemsSource="{Binding DanhSachPhanHoi}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource AnswerBoxStyle}">
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#166534"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- GÓP Ý -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Góp ý thêm"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,10"/>
                    <TextBox Style="{StaticResource MultiLineTextBoxStyle}"
                             Text="{Binding GopYThem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- BUTTON -->
                <StackPanel Grid.Row="8"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Gửi phản hồi"
                            Margin="0,0,10,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding GuiPhanHoiCommand}"/>

                    <Button Content="Nhập lại"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding NhapLaiCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>