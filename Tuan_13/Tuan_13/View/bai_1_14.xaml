<Window x:Class="Tuan_13.View.bai_1_14"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Viewer="clr-namespace:SAPBusinessObjects.WPF.Viewer;assembly=SAPBusinessObjects.WPF.Viewer"
        mc:Ignorable="d"
        Title="B1"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#DCDCDC"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">

            <DockPanel LastChildFill="False">

                <TextBlock Text="Mã lớp:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="cboMaLop"
                          Width="220"
                          Height="30"
                          ItemsSource="{Binding DanhSachMaLop}"
                          SelectedItem="{Binding SelectedMaLop}"
                          Margin="0,0,12,0"/>

                <Button Width="120"
                        Height="30"
                        Content="Show Report"
                        Click="Button_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="#DCDCDC"
                BorderThickness="1">

            <Viewer:CrystalReportsViewer x:Name="myreport"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>