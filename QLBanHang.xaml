<Window x:Class="Tuan_7.Views.QLBanHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Tuan_7.ViewModels"
        xmlns:views="clr-namespace:Tuan_7.Views"
        mc:Ignorable="d"
        Title="QLBanHang"
        Height="650"
        Width="1050"
        MinHeight="650"
        MinWidth="1050"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:LapHoaDonViewModel}">
            <views:UcLapHoaDon/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DanhSachHoaDonViewModel}">
            <views:UcDanhSachHoaDon/>
        </DataTemplate>
        
        <!-- Menu button -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#2D62ED"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Background" Value="#2D62ED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F4FCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card style -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="14"
                            Background="#DCEFFF">
                        <Grid>
                            <Ellipse Width="14"
                                     Height="14"
                                     Fill="#4F7DF3"
                                     Stroke="White"
                                     StrokeThickness="1.5"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Cafe Sinh Viên"
                               Margin="18,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#19376D"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Grid.Row="2"
                            VerticalAlignment="Top">
                    <Button Content="Lập hóa đơn"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding LapHoaDonCommand}"/>

                    <Button Content="Danh sách hóa đơn"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding DanhSachHoaDonCommand}"/>

                    <Separator Margin="0,12,0,12"
                               Background="#E5E7EB"/>

                    <Button Content="Thống kê"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ThongKeCommand}"/>
                </StackPanel>

                <!-- Exit -->
                <Button Grid.Row="3"
                        Content="Thoát"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ThoatCommand}"/>

                <!-- Footer -->
                <TextBlock Grid.Row="5"
                           Text="© 2025 - WPF Lab 7"
                           HorizontalAlignment="Center"
                           Foreground="#7C8BA1"
                           FontSize="12"/>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="105"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TieuDeTrang}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>

                        <TextBlock Text="{Binding MoTaTrang}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <DatePicker Width="190"
                                    Height="44"
                                    Margin="0,0,16,0"
                                    Padding="8,0"
                                    VerticalContentAlignment="Center"
                                    SelectedDate="{Binding NgayLap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="+ Hóa đơn mới"
                                Width="196"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding HoaDonMoiCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
        Style="{StaticResource CardBorderStyle}">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        </Grid>
    </Grid>
</Window>