<UserControl x:Class="Tuan_10.Views.bai1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Tuan_10.Views"
             mc:Ignorable="d"
             Width="781"
             Height="372"
             Background="White">

    <Grid Margin="10">
        <!-- Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="67*" />
            <ColumnDefinition Width="89*" />
        </Grid.ColumnDefinitions>

        <!-- THÔNG TIN KHOA -->
        <GroupBox Header="THÔNG TIN KHOA" Margin="5">
            <StackPanel Margin="10">

                <TextBlock Text="Mã khoa:" />
                <TextBox Text="{Binding MaKhoaInput, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,5,0,10"/>

                <TextBlock Text="Tên khoa:" />
                <TextBox Text="{Binding TenKhoaInput, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,5,0,15"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="Thêm" Command="{Binding AddCommand}" Width="70" Margin="5"/>
                    <Button Content="Sửa" Command="{Binding EditCommand}" Width="70" Margin="5"/>
                    <Button Content="Xóa" Command="{Binding DeleteCommand}" Width="70" Margin="5"/>
                </StackPanel>

            </StackPanel>
        </GroupBox>

        <!-- DANH SÁCH KHOA -->
        <GroupBox Header="DANH SÁCH KHOA"
                  Grid.Column="1"
                  Margin="5">

            <Grid Margin="10">
                <DataGrid x:Name="dgKhoa"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding DS_Khoa}"
                          SelectedItem="{Binding SelectedKhoa}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã khoa"
                                            Binding="{Binding MaKhoa}"
                                            Width="*" />

                        <DataGridTextColumn Header="Tên khoa"
                                            Binding="{Binding TenKhoa}"
                                            Width="2*" />
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </GroupBox>

    </Grid>
</UserControl>