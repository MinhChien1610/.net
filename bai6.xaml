<UserControl x:Class="Tuan_10.Views.bai6"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="850"
             Height="500"
             Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bộ lọc -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Môn học:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <ComboBox Grid.Column="1"
                      Height="25"
                      ItemsSource="{Binding ListMonHoc}"
                      SelectedItem="{Binding SelectedFilterMon}"
                      DisplayMemberPath="TenMonHoc"/>

            <TextBlock Grid.Column="2"
                       Text="Năm học:"
                       VerticalAlignment="Center"
                       Margin="15,0,10,0"/>

            <ComboBox Grid.Column="3"
                      Height="25"
                      ItemsSource="{Binding ListNamHoc}"
                      SelectedItem="{Binding SelectedFilterNam}"/>

            <TextBlock Grid.Column="4"
                       Text="Học kỳ:"
                       VerticalAlignment="Center"
                       Margin="15,0,10,0"/>

            <ComboBox Grid.Column="5"
                      Height="25"
                      ItemsSource="{Binding ListHocKy}"
                      SelectedItem="{Binding SelectedFilterHK}"/>
        </Grid>

        <!-- Nút -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,15,0,10">
            <Button Content="Tải danh sách sinh viên"
                    Width="160"
                    Height="30"
                    Command="{Binding LoadListCommand}"/>

            <Button Content="Lưu điểm"
                    Width="100"
                    Height="30"
                    Margin="15,0,0,0"
                    Command="{Binding SavePointsCommand}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ListSinhVienNhapDiem}"
                  CanUserAddRows="False"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SV"
                                    Binding="{Binding MaSinhVien}"
                                    IsReadOnly="True"
                                    Width="120"/>

                <DataGridTextColumn Header="Họ tên"
                                    Binding="{Binding HoTen}"
                                    IsReadOnly="True"
                                    Width="220"/>

                <DataGridTextColumn Header="Lớp"
                                    Binding="{Binding MaLop}"
                                    IsReadOnly="True"
                                    Width="120"/>

                <DataGridTextColumn Header="Điểm"
                                    Binding="{Binding Diem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>