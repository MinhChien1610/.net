<UserControl x:Class="Tuan_10.Views.bai4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="900"
             Height="500"
             Background="White">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FORM -->
        <Border Margin="5"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="5">
            <StackPanel Margin="15">

                <TextBlock Text="THÔNG TIN SINH VIÊN"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Mã sinh viên:"/>
                <TextBox Height="25"
                         Margin="0,5,0,10"
                         Text="{Binding SelectedSinhVien.MaSinhVien, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Họ tên:"/>
                <TextBox Height="25"
                         Margin="0,5,0,10"
                         Text="{Binding SelectedSinhVien.HoTen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Giới tính:"/>
                <ComboBox Height="25"
                          Margin="0,5,0,10"
                          SelectedValue="{Binding SelectedSinhVien.GioiTinh, Mode=TwoWay}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="Nam"/>
                    <ComboBoxItem Content="Nữ"/>
                    <ComboBoxItem Content="Khác"/>
                </ComboBox>

                <TextBlock Text="Ngày sinh:"/>
                <DatePicker Height="25"
                            Margin="0,5,0,10"
                            SelectedDate="{Binding SelectedSinhVien.NgaySinh, Mode=TwoWay}"/>

                <TextBlock Text="Lớp:"/>
                <ComboBox Height="25"
                          Margin="0,5,0,20"
                          ItemsSource="{Binding ListLop}"
                          DisplayMemberPath="MaLop"
                          SelectedValuePath="MaLop"
                          SelectedValue="{Binding SelectedSinhVien.MaLop, Mode=TwoWay}"/>

                <UniformGrid Columns="5">
                    <Button Content="Thêm" Margin="2" Command="{Binding AddCommand}"/>
                    <Button Content="Sửa" Margin="2" Command="{Binding EditCommand}"/>
                    <Button Content="Xóa" Margin="2" Command="{Binding DeleteCommand}"/>
                    <Button Content="Lưu" Margin="2" Command="{Binding SaveCommand}"/>
                    <Button Content="Hủy" Margin="2" Command="{Binding CancelCommand}"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- GRID -->
        <Border Grid.Column="1"
                Margin="5"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="5">
            <DockPanel Margin="10">

                <TextBlock DockPanel.Dock="Top"
                           Text="DANH SÁCH SINH VIÊN"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <DataGrid ItemsSource="{Binding ListSinhVien}"
                          SelectedItem="{Binding SelectedSinhVien, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SV"
                                            Binding="{Binding MaSinhVien}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Họ tên"
                                            Binding="{Binding HoTen}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Giới tính"
                                            Binding="{Binding GioiTinh}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Ngày sinh"
                                            Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Mã lớp"
                                            Binding="{Binding MaLop}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

            </DockPanel>
        </Border>
    </Grid>
</UserControl>