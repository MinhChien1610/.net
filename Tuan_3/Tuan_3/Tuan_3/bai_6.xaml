<Window x:Class="Tuan_3.bai_6"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="bai_6" Height="887" Width="593">
    <Grid Margin="10">
        <TabControl x:Name="tab_main">

            <TabItem Header="Khảo sát">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <GroupBox Header="Thông tin cá nhân" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Họ và tên:" Grid.Row="0"/>
                                <TextBox x:Name="txt_ten"
                                         Grid.Row="0" Grid.Column="1" Height="30"/>

                                <TextBlock Text="Lớp/Khoa:" Grid.Row="1" Margin="0,10,0,0"/>
                                <ComboBox x:Name="cb_lop"
                                          Grid.Row="1" Grid.Column="1" Height="30" Margin="0,10,0,0"/>

                                <TextBlock Text="Giới tính:" Grid.Row="2" Margin="0,10,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <RadioButton x:Name="rb_nam" Content="Nam" Margin="0,0,20,0"/>
                                    <RadioButton x:Name="rb_nu" Content="Nữ" Margin="0,0,20,0"/>
                                    <RadioButton x:Name="rb_khac" Content="Khác"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Ý kiến của bạn" Margin="0,0,0,15">
                            <StackPanel Margin="10">

                                <TextBlock Text="1. Đánh giá chất lượng giảng dạy môn học:" Height="26"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                    <RadioButton x:Name="rb_gd_ratTot" Content="Rất tốt" Margin="30,0,70,0"/>
                                    <RadioButton x:Name="rb_gd_tot" Content="Tốt" Margin="0,0,65,0"/>
                                    <RadioButton x:Name="rb_gd_tb" Content="Trung bình" Margin="0,0,50,0"/>
                                    <RadioButton x:Name="rb_gd_kem" Content="Kém"/>
                                </StackPanel>

                                <TextBlock Text="2. Mức độ hài lòng với cơ sở vật chất:" Height="25"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                    <RadioButton x:Name="rb_csvc_ratHL" Content="Rất hài lòng" Margin="30,0,40,0"/>
                                    <RadioButton x:Name="rb_csvc_hl" Content="Hài lòng" Margin="0,0,40,0"/>
                                    <RadioButton x:Name="rb_csvc_bt" Content="Bình thường" Margin="0,0,40,0"/>
                                    <RadioButton x:Name="rb_csvc_khl" Content="Không hài lòng" Padding="10,-1,0,0"/>
                                </StackPanel>

                                <TextBlock Text="3. Bạn muốn học online không?" Height="26"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                    <RadioButton x:Name="rb_online_co" Content="Có" Margin="30,0,90,0"/>
                                    <RadioButton x:Name="rb_online_khong" Content="Không" Margin="0,0,48,0"/>
                                    <RadioButton x:Name="rb_online_tuy" Content="Tùy trường hợp"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        
                        <GroupBox Header="Đề xuất cải thiện (chọn nhiều)">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="cb_giamTai" Content="Giảm tải học phần" Height="26"/>
                                <CheckBox x:Name="cb_thucHanh" Content="Tăng cường thực hành" Height="25"/>
                                <CheckBox x:Name="cb_wifi" Content="Cải thiện tốc độ Wifi" Height="25"/>
                                <CheckBox x:Name="cb_giangVien" Content="Giảng viên nhiệt tình hơn" Height="25"/>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Khác:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txt_khac" Width="452" Height="30"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Ý kiến đóng góp thêm" Margin="0,15,0,15">
                            <TextBox x:Name="txt_yKienThem"
                                     Height="80"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Margin="10"/>
                        </GroupBox>
                        
                        <Button x:Name="btn_gui"
                                Content="Gửi khảo sát &amp; Xem lại"
                                Height="45" Width="250"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"
                                Click="btnClick_gui"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Kết quả của bạn">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="KẾT QUẢ KHẢO SÁT CỦA BẠN"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <Border Grid.Row="1"
                            BorderBrush="#4A90E2"
                            BorderThickness="2"
                            CornerRadius="10"
                            Padding="10">
                        <TextBox x:Name="tb_ketQua"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 BorderThickness="0"/>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <Button x:Name="btn_lamMoi"
                                Content="Làm khảo sát mới"
                                Width="160" Height="40"
                                Margin="10"
                                Click="btnClick_lamMoi"/>
                        <Button x:Name="btn_thoat"
                                Content="Thoát"
                                Width="120" Height="40"
                                Margin="10"
                                Click="btnClick_thoat"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
