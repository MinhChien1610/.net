<Window x:Class="Tuan_3.bai_3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_3"
        mc:Ignorable="d"
        Title="bai_3" Height="650" Width="900" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="12" 
                Margin="39,30,10,29"
                BorderThickness="1"
                BorderBrush="Black">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="49*"></RowDefinition>
                    <RowDefinition Height="85*"></RowDefinition>
                    <RowDefinition Height="85*"></RowDefinition>
                    <RowDefinition Height="85*"></RowDefinition>
                    <RowDefinition Height="208*"></RowDefinition>
                    <RowDefinition Height="64*"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left" 
                           Margin="25,0,0,0" Height="24" Width="159">
                    Thông tin đặt món
                </TextBlock>

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="107">
                    Tên khách hàng:
                </TextBlock>

                <TextBlock Grid.Row="2"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="91">
                    Số điện thoại:
                </TextBlock>

                <TextBlock Grid.Row="3"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="67">
                    Chọn bàn:
                </TextBlock>

                <TextBlock Grid.Row="4"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="259">
                    Chọn món ăn (có thể chọn nhiều món):
                </TextBlock>

                <TextBox Grid.Row="1" 
                         Margin="25,35,29,10"
                         VerticalContentAlignment="Center"
                         x:Name="txt_name"
                         FontSize="12"/>

                <TextBox Grid.Row="2" 
                         Margin="25,35,29,10"
                         VerticalContentAlignment="Center"
                         x:Name="txt_phone"
                         FontSize="12"/>

                <ComboBox Grid.Row="3" 
                         Margin="25,35,29,10"
                         VerticalContentAlignment="Center"
                          x:Name="ccb_table"
                         FontSize="12">
                    <ComboBoxItem>Bàn 1</ComboBoxItem>
                    <ComboBoxItem>Bàn 2</ComboBoxItem>
                    <ComboBoxItem>Bàn 3</ComboBoxItem>
                    <ComboBoxItem>Bàn 4</ComboBoxItem>
                </ComboBox>

                <ListBox Grid.Row="4"
                         Margin="25,35,29,10"
                         x:Name="lb_food"
                         FontSize="12"
                         SelectionMode="Multiple"
                         >
                    <ListBoxItem>Phở</ListBoxItem>
                    <ListBoxItem>Bún bò</ListBoxItem>
                    <ListBoxItem>Cơm tấm</ListBoxItem>
                    <ListBoxItem>Trà sữa</ListBoxItem>
                    <ListBoxItem>Nước ngọt</ListBoxItem>
                </ListBox>

                <Button Grid.Row="5"
                        Margin="260,10,29,22"
                        x:Name="btn_xacNhan"
                        Click="btnClick_xacNhan">
                    Xác nhận
                </Button>

            </Grid>

        </Border>

        <Border Grid.Column="1"
                CornerRadius="12" 
                Margin="10,30,39,29"
                BorderThickness="1"
                BorderBrush="Black">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="49*"></RowDefinition>
                    <RowDefinition Height="151*"></RowDefinition>
                    <RowDefinition Height="208*"></RowDefinition>
                    <RowDefinition Height="167*"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left" 
                           Margin="25,0,0,0" Height="24" Width="159">
                    Thông tin hiển thị
                </TextBlock>

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontWeight="Bold"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="177">
                    Thông tin khách hàng
                </TextBlock>

                <TextBox Grid.Row="1" 
                         Margin="25,35,29,10"
                         x:Name="txt_infomation"
                         FontSize="12"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="2"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontWeight="Bold"
                           FontSize="15" Margin="25,10,0,0" Height="20" Width="177">
                    Danh sách món đã chọn
                </TextBlock>

                <ListBox Grid.Row="2" 
                         Margin="25,35,29,8"
                         x:Name="lb_listFood"
                         FontSize="12"/>

                <StackPanel Grid.Row="3"
                            
                            Margin="119,10,29,114" 
                            Orientation="Horizontal">

                    <Button Width="112"
                            Height="31.89333333"
                            x:Name="btn_deleteFood"
                            Click="btnClick_deleteFood">
                        Xóa món
                    </Button>

                    <Button Width="112"
                            Background="LimeGreen" 
                            Margin="20,0,0,0"
                            Height="31.89333333"
                            x:Name="btn_orderFood"
                            Click="btnClick_orderFood">
                        Đặt món
                    </Button>

                </StackPanel>
                
            </Grid>
            
        </Border>
        
    </Grid>
</Window>
