<Window x:Class="Tuan_3.bai_2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_3"
        mc:Ignorable="d"
        Title="bai_2" Height="700" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="91*"></RowDefinition>
            <RowDefinition Height="485*"></RowDefinition>
            <RowDefinition Height="108*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock
                   FontSize="35"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold">
            Thông tin - Sở thích cá nhân
        </TextBlock>

        <TabControl Margin="12,91,12,0" Grid.RowSpan="2">

            <TabItem Header="Nhập thông tin cá nhân"
                     x:Name="ti_nhapThongTin"
                     FontSize="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120*"></RowDefinition>
                        <RowDefinition Height="183*"></RowDefinition>
                        <RowDefinition Height="149*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               FontWeight="Bold"
                               Margin="43,20,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="27" Width="100">
                        Họ và tên
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               FontWeight="Bold"
                               Margin="43,10,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="27" Width="94">
                        Giới tính
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               FontWeight="Bold"
                               Margin="43,91,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Width="115" Height="27">
                        Ngày sinh
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               FontWeight="Bold"
                               Margin="43,10,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="26" Width="95">
                        Quốc tịch
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               FontWeight="Bold"
                               Margin="43,20,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="27" Width="131">
                        Nghề nghiệp
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               FontWeight="Bold"
                               Margin="43,10,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="27" Width="88">
                        Sở thích
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               FontWeight="Bold"
                               Margin="43,10,0,0"
                               FontSize="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Height="26" Width="86" RenderTransformOrigin="0.4,0.781">
                        Kỹ năng
                    </TextBlock>

                    <TextBox Grid.Row="0"
                             Grid.Column="0" 
                             Margin="43,60,40,12"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             x:Name="txt_hoVaTen"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="1" 
                             Margin="43,60,40,10"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             x:Name="txt_ngheNghiep"/>

                    <RadioButton Grid.Row="1"
                                 Grid.Column="0"
                                 GroupName="gioi_tinh"
                                 x:Name="rb_nam"
                                 VerticalContentAlignment="Center"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 FontSize="18" Margin="71,48,0,0" Height="23" Width="57">
                        Nam
                    </RadioButton>

                    <RadioButton Grid.Row="1"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 GroupName="gioi_tinh"
                                 x:Name="rb_nu"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 FontSize="18" Margin="198,47,0,0" Height="23" Width="43">
                        Nữ
                    </RadioButton>

                    <DatePicker Grid.Row="1"
                                Grid.Column="0" 
                                Margin="43,131,40,0"
                                x:Name="dp_date"
                                FontSize="18"
                                VerticalContentAlignment="Center" Height="40" VerticalAlignment="Top"/>

                    <ComboBox Grid.Row="2"
                              Grid.Column="0" 
                              Margin="43,48,40,55"
                              FontSize="18"
                              VerticalContentAlignment="Center"
                              x:Name="cbb_quocTich">

                        <ComboBoxItem FontSize="18">Việt Nam</ComboBoxItem>
                        <ComboBoxItem FontSize="18">Hàn Quốc</ComboBoxItem>
                        <ComboBoxItem FontSize="18">Nhật Bản</ComboBoxItem>
                        <ComboBoxItem FontSize="18">Đức</ComboBoxItem>

                    </ComboBox>

                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              x:Name="cb_docSach"
                              FontSize="18"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" 
                              Margin="43,48,0,0" Height="23" Width="92">
                        Đọc sách
                    </CheckBox>

                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              x:Name="cb_ngheNhac"
                              FontSize="18"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" 
                              Margin="43,76,0,0" Height="23" Width="106">
                        Nghe nhạc
                    </CheckBox>

                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              x:Name="cb_theThao"
                              FontSize="18"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" 
                              Margin="43,103,0,0" Height="23" Width="90">
                        Thể thao
                    </CheckBox>

                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              x:Name="cb_duLich"
                              FontSize="18"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" 
                              Margin="43,131,0,0" Height="23" Width="81">
                        Du dịch
                    </CheckBox>

                    <ListBox Grid.Row="2"
                             Grid.Column="1" 
                             Margin="43,41,40,23"
                             x:Name="lb_kyNang">
                        <ListBoxItem>C# / .Net</ListBoxItem>
                        <ListBoxItem>WPF / XAML</ListBoxItem>
                        <ListBoxItem>SQL Server</ListBoxItem>
                        <ListBoxItem>HTML / CSS</ListBoxItem>
                        <ListBoxItem>Kỹ năng giao tiếp</ListBoxItem>
                    </ListBox>

                </Grid>

            </TabItem>

            <TabItem Header="Xem thông tin đã nhập"
                     x:Name="ti_xemThongTin"
                     FontSize="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="113*"></RowDefinition>
                        <RowDefinition Height="95*"></RowDefinition>
                        <RowDefinition Height="104*"></RowDefinition>
                        <RowDefinition Height="140*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="333*"/>
                        <ColumnDefinition Width="385*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,30,0,0" Height="27" Width="91" Grid.ColumnSpan="2">
                        Họ và tên
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               FontSize="18"
                               x:Name="txt_hoVaTen_Text"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,62,0,0" Width="316" Height="41" Grid.ColumnSpan="2">
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,10,0,0" Height="27" Width="81" Grid.ColumnSpan="2">
                        Giới tính
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               x:Name="txt_gioiTinh_Text"
                               FontSize="18"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,42,0,0" Width="316" Height="41" Grid.ColumnSpan="2">
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,11,0,0" Width="146" Height="30" Grid.ColumnSpan="2">
                        Ngày sinh
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               x:Name="txt_ngaySinh_Text"
                               FontSize="18"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,41,0,0" Width="316" Height="41" Grid.ColumnSpan="2">
                    </TextBlock>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="52,10,0,0" Height="27" Width="91" Grid.ColumnSpan="2">
                         Quốc tịch
                    </TextBlock>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               x:Name="txt_quocTich_Text"
                               FontSize="18"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left" Margin="52,0,0,0" Width="316" Height="41" Grid.ColumnSpan="2">
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,30,0,0">
                        Nghề nghiệp
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               x:Name="txt_ngheNghiep_Text"
                               FontSize="18"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,63,0,0" Width="316" Height="41">
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,10,0,0">
                         Sở thích
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               FontSize="18"
                               x:Name="txt_soThich_Text"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,42,0,0" Width="316" Height="41"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,10,0,0">
                        Kỹ năng
                    </TextBlock>

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               FontSize="18"
                               x:Name="txt_kyNang_Text"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,41,0,0" Width="316" Height="41"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" Margin="55,10,0,0">
                        Ghi chú
                    </TextBlock>

                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               FontSize="18"
                               x:Name="txt_ghiChu_Text"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left" Margin="55,0,0,0" Width="316" Height="41"/>
                </Grid>

            </TabItem>

        </TabControl>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    Margin="200,15,168,31">

            <Button FontSize="20"
                    Background="DodgerBlue" 
                    Width="177"
                    x:Name="btn_ThongTin"
                    Click="btnClick_ThongTin">
                Xem thông tin
            </Button>

            <Button FontSize="20"
                    Background="Red"
                    x:Name="btn_Thoat"
                    Click="btnClick_Thoat"
                    Width="177" Margin="40,0,0,0">
                Thoát
            </Button>

        </StackPanel>

    </Grid>
</Window>
