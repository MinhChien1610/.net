<Window x:Class="Tuan_3.bai_4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_3"
        mc:Ignorable="d"
        Title="bai_4" Height="745" Width="629">
    <Grid>
        <TabControl Margin="25,25,25,25"
                     SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header=" Đặt món">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="112*"></RowDefinition>
                        <RowDefinition Height="73*"></RowDefinition>
                        <RowDefinition Height="72*"></RowDefinition>
                        <RowDefinition Height="73*"></RowDefinition>
                        <RowDefinition Height="120*"></RowDefinition>
                        <RowDefinition Height="154*"></RowDefinition>
                        <RowDefinition Height="47*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="82" 
                              Header="Thông tin khách hàng" 
                              VerticalAlignment="Top" 
                              Width="517" 
                              BorderBrush="Black" 
                              Margin="0,20,0,0"
                              Grid.Row="0"
                              FontWeight="Bold"/>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="63" 
                              Header="Chọn loại đồ uống" 
                              VerticalAlignment="Center" 
                              Width="517" 
                              BorderBrush="Black" 
                              Grid.Row="1"
                              FontWeight="Bold"/>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="63" 
                              Header="Size" 
                              VerticalAlignment="Center" 
                              Width="517" 
                              BorderBrush="Black" 
                              Grid.Row="2"
                              FontWeight="Bold"/>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="63" 
                              Header="Topping (chọn nhiều)" 
                              VerticalAlignment="Center" 
                              Width="517" 
                              BorderBrush="Black" 
                              Grid.Row="3"
                              FontWeight="Bold"/>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="106" 
                              Header="Ghi chú" 
                              VerticalAlignment="Center" 
                              Width="517" 
                              BorderBrush="Black" 
                              Grid.Row="4"
                              FontWeight="Bold"/>

                    <GroupBox HorizontalAlignment="Center" 
                              Height="134" 
                              Header="Đơn hàng hiện tại" 
                              VerticalAlignment="Center" 
                              Width="517" 
                              BorderBrush="Black" 
                              Grid.Row="5"
                              FontWeight="Bold"/>

                    <StackPanel Grid.Row="6" 
                                Margin="271,5,10,5"
                                Orientation="Horizontal">

                        <Button Width="115"
                                Foreground="White"
                                FontWeight="Bold"
                                Background="MediumPurple"
                                x:Name="btn_themDon"
                                Click="btnClick_themDon">
                            Thêm vào đơn
                        </Button>

                        <Button Width="115" 
                                Margin="35,0,0,0"
                                FontWeight="Bold"
                                x:Name="btn_xoaDon"
                                Click="btnClick_xoaDon">
                            Xóa đơn hiện tại
                        </Button>

                    </StackPanel>

                    <TextBlock VerticalAlignment="Top"
                               Height="18" 
                               Margin="57,43,409,0">
                        Tên khách hàng:
                    </TextBlock>

                    <TextBlock VerticalAlignment="Top"
                               Height="18" 
                               Margin="310,43,177,0">
                        Số điện thoại:
                    </TextBlock>

                    <TextBox Margin="57,66,312,19"
                             x:Name="txt_name"
                             Grid.Row="0"
                             VerticalContentAlignment="Center"/>

                    <TextBox Margin="310,66,59,19"
                             x:Name="txt_phone"
                             Grid.Row="0"
                             VerticalContentAlignment="Center"/>

                    <ComboBox Grid.Row="1"
                              x:Name="cbb_drink"
                              Margin="57,27,59,14"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem>Trà lài sen vải</ComboBoxItem>
                        <ComboBoxItem>Trà sữa ô long</ComboBoxItem>
                        <ComboBoxItem>Matcha latte</ComboBoxItem>
                        <ComboBoxItem>Trà ổi hồng nha đam</ComboBoxItem>
                        <ComboBoxItem>Trà sữa lài</ComboBoxItem>
                        <ComboBoxItem>Nước dừa</ComboBoxItem>
                    </ComboBox>

                    <RadioButton Grid.Row="2"
                                 x:Name="rb_sizeM"
                                 GroupName="size"
                                 VerticalContentAlignment="Center" 
                                 Margin="57,29,389,14">
                        M (500ml)
                    </RadioButton>

                    <RadioButton Grid.Row="2"
                                 x:Name="rb_sizeL"
                                 GroupName="size"
                                 VerticalContentAlignment="Center" 
                                 Margin="226,31,195,17">
                        L (700ml) + 5.000đ
                    </RadioButton>

                    <CheckBox Grid.Row="3"
                              x:Name="cb_tranChau"
                              VerticalContentAlignment="Center" 
                              Margin="57,28,426,18">
                        Trân châu
                    </CheckBox>

                    <CheckBox Grid.Row="3"
                              x:Name="cb_pudding"
                              VerticalContentAlignment="Center" 
                              Margin="141,28,347,18">
                        Pudding
                    </CheckBox>

                    <CheckBox Grid.Row="3"
                              x:Name="cb_thachTraiCay"
                              VerticalContentAlignment="Center" 
                              Margin="226,28,236,18">
                        Thạch trái cây
                    </CheckBox>

                    <CheckBox Grid.Row="3"
                              x:Name="cb_kemCheese"
                              VerticalContentAlignment="Center" 
                              Margin="342,28,125,18" RenderTransformOrigin="0.63,0.549">
                        Kem cheese
                    </CheckBox>

                    <CheckBox Grid.Row="3"
                              x:Name="cb_thachDua"
                              VerticalContentAlignment="Center" 
                              Margin="448,28,34,18">
                        Thạch dừa
                    </CheckBox>

                    <TextBox Grid.Row="4"
                             Margin="44,32,47,24"
                             x:Name="txt_ghiChu"/>

                    <ListBox Grid.Row="5" 
                             Margin="44,37,47,28"
                             x:Name="lb_donHang"/>

                </Grid>
            </TabItem>

            <TabItem Header="Xem &amp; xác nhận"
                     x:Name="ti_xemThongTin">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="61*"></RowDefinition>
                        <RowDefinition Height="105*"></RowDefinition>
                        <RowDefinition Height="325*"></RowDefinition>
                        <RowDefinition Height="85*"></RowDefinition>
                        <RowDefinition Height="75*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="25"
                               FontWeight="Bold"
                               Foreground="MediumPurple"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Center" 
                               Height="33" Width="259" Margin="0,18,0,0">
                        HÓA ĐƠN ĐẶT HÀNG
                    </TextBlock>

                    <Border Grid.Row="1" 
                            CornerRadius="12" 
                            BorderThickness="1" 
                            BorderBrush="#D0D0D0" 
                            Padding="15" 
                            Margin="10,10,10,10">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Tên khách hàng:" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" 
                                       x:Name="tb_name"
                                       Margin="5,0,20,0" 
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Số điện thoại:"
                                       Grid.Column="2" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="3"
                                       Margin="5,0,0,0" 
                                       x:Name="tb_phone"
                                       VerticalAlignment="Center"/>
                        </Grid>

                    </Border>

                    <GroupBox Grid.Row="2"
                              Header="Chi tiết đơn hàng" 
                              Margin="10,10,10,10"
                              FontWeight="Bold">

                        <ListBox BorderBrush="White"
                                 x:Name="lb_chiTiet"></ListBox>
                    </GroupBox>

                    <Border Grid.Row="3"
                            CornerRadius="12" 
                            BorderThickness="2"
                            BorderBrush="PaleVioletRed" 
                            Background="#FFFFDBD5"
                            Margin="10,10,10,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="401*"></ColumnDefinition>
                                <ColumnDefinition Width="148*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       FontSize="23"
                                       FontWeight="Bold" Margin="251,0,0,0" Height="33" Width="140" RenderTransformOrigin="0.664,0.516">
                                TỔNG TIỀN:
                            </TextBlock>

                            <TextBlock Margin="5,16,5,16"
                                       Grid.Column="1"
                                       x:Name="tb_tongTien"
                                       FontSize="23"
                                       FontWeight="Bold"
                                       Foreground="Red"/>

                        </Grid>

                    </Border>

                    <StackPanel Grid.Row="4" 
                                Margin="87,13,-28,10"
                                Orientation="Horizontal">

                        <Button Width="127"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="MediumPurple"
                                x:Name="btn_inHoaDon"
                                Click="btnClick_inHoaDon">
                            IN HÓA ĐƠN
                        </Button>

                        <Button Width="138" 
                                Margin="30,0,0,0"
                                FontWeight="Bold"
                                x:Name="btn_huyDon"
                                Click="btnClick_huyDon">
                            HỦY ĐƠN HÀNG
                        </Button>

                        <Button Width="137" 
                                Margin="30,0,0,0"
                                FontWeight="Bold"
                                Background="#FF07B5EF"
                                x:Name="btn_datHang"
                                Click="btnClick_datHang">
                            ĐẶT HÀNG
                        </Button>

                    </StackPanel>

                </Grid>

            </TabItem>

        </TabControl>

    </Grid>
</Window>
