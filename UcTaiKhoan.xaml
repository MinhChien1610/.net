<UserControl x:Class="Tuan_7.Views.UcTaiKhoan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="950"
             Background="#F8FAFC"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20,14">
            <TextBlock Text="QUẢN LÝ TÀI KHOẢN"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
        </Border>

        <!-- DANH SÁCH -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Danh sách tài khoản"
                           Style="{StaticResource SectionTitleStyle}"/>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DanhSach}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderBrush="#DCDDE1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          RowHeight="38"
                          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50"/>
                        <DataGridTextColumn Header="Số TK" Binding="{Binding SoTK}" Width="140"/>
                        <DataGridTextColumn Header="Chủ tài khoản" Binding="{Binding ChuTK}" Width="180"/>
                        <DataGridTextColumn Header="Loại TK" Binding="{Binding LoaiTK}" Width="120"/>
                        <DataGridTextColumn Header="Số dư"
                                            Binding="{Binding SoDu, StringFormat={}{0:N0}}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- FORM + THAO TÁC -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Cột trái -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin tài khoản"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Số tài khoản" Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding SoTK, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Chủ tài khoản"
                               Margin="0,12,0,6"
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding ChuTK, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Số dư ban đầu"
                               Margin="0,12,0,6"
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding SoDu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Cột giữa -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin bổ sung"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Loại tài khoản" Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding DanhSachLoaiTK}"
                              SelectedItem="{Binding LoaiTK, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Trạng thái"
                               Margin="0,12,0,6"
                               Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding DanhSachTrangThai}"
                              SelectedItem="{Binding TrangThai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Ghi chú"
                               Margin="0,12,0,6"
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding GhiChu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Cột phải -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thao tác"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Button Content="+ Thêm"
                            Margin="0,0,0,10"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddCommand}"/>

                    <Button Content="Sửa"
                            Margin="0,0,0,10"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding EditCommand}"/>

                    <Button Content="Lưu"
                            Margin="0,0,0,10"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveCommand}"/>

                    <Button Content="Xóa"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>