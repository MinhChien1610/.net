<UserControl x:Class="Tuan_10.Views.bai3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="783"
             Height="292"
             Background="White">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="79*" />
            <ColumnDefinition Width="77*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="THÔNG TIN LỚP"
                  Grid.Column="0"
                  Margin="5">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,5">
                    <TextBlock Text="Mã lớp" />
                    <TextBox Height="25"
                             Text="{Binding LopDangChon.MaLop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,5">
                    <TextBlock Text="Mã khoa" />
                    <ComboBox Height="25"
                              ItemsSource="{Binding DanhSachKhoa}"
                              DisplayMemberPath="TenKhoa"
                              SelectedValuePath="MaKhoa"
                              SelectedValue="{Binding LopDangChon.MaKhoa, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button Content="Thêm" Width="60" Margin="5" Command="{Binding AddCommand}" />
                    <Button Content="Sửa" Width="60" Margin="5" Command="{Binding EditCommand}" />
                    <Button Content="Xóa" Width="60" Margin="5" Command="{Binding DeleteCommand}" />
                    <Button Content="Lưu" Width="60" Margin="5" Command="{Binding SaveCommand}" />
                    <Button Content="Hủy" Width="60" Margin="5" Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Header="DANH SÁCH LỚP"
                  Grid.Column="1"
                  Margin="5">
            <Grid Margin="10">
                <DataGrid AutoGenerateColumns="False"
                          ItemsSource="{Binding DanhSachLop}"
                          SelectedItem="{Binding LopDangChon, Mode=TwoWay}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã lớp"
                                            Binding="{Binding MaLop}"
                                            Width="*" />
                        <DataGridTextColumn Header="Mã khoa"
                                            Binding="{Binding MaKhoa}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>