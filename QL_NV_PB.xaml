<Window x:Class="Tuan_6.View.QL_NV_PB"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_6.View"
        mc:Ignorable="d"
        Title="QL_NV_PB"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Quản lý nhân viên theo phòng ban (MVVM)"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#333"/>
                <TextBlock Text="Chọn phòng ban bên trái để xem và thao tác nhân viên bên phải."
                           Foreground="#666"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Border Background="#218838"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="15,8"
                    CornerRadius="12"
                    Width="200"
                    Margin="0,0,20,0">
                <TextBlock Text="{Binding TotalEmployeeCount, StringFormat='Tổng nhân viên: {0}'}"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"/>
            </Border>
        </Grid>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: PHÒNG BAN -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Margin="0,0,10,0"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Phòng ban"
                               FontWeight="Bold"
                               Foreground="#FF4B2B"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <!-- Đổi TreeView thành ListBox để bind SelectedDepartment đúng MVVM -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Departments}"
                             SelectedItem="{Binding SelectedDepartment}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8"
                                        Margin="0,3"
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <TextBlock Text="{Binding TenPhongBan}"
                                               FontSize="14"
                                               Foreground="#333"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    CornerRadius="8"
                                                    Padding="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFF3F4F6"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFE8F0FE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Grid.Row="2"
                            Background="#F8F9FA"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Quản lý phòng ban"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"
                                       Foreground="#555"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding NewDepartmentName, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="5"
                                         VerticalContentAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Command="{Binding AddDepartmentCommand}"
                                        Content="+ Thêm"
                                        Margin="5,0,0,0"
                                        Padding="8,2"
                                        Background="#E9ECEF"/>
                            </Grid>

                            <Button Command="{Binding RemoveDepartmentCommand}"
                                    Background="#D93025"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑" Margin="0,0,5,0"/>
                                    <TextBlock Text="Xóa phòng ban"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT: NHÂN VIÊN -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- DANH SÁCH -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <TextBlock Text="Danh sách nhân viên"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="(Lọc theo phòng ban đang chọn)"
                                       Foreground="#999"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>

                            <Border DockPanel.Dock="Right"
                                    Background="#E8F0FE"
                                    CornerRadius="12"
                                    Padding="12,5"
                                    Width="210"
                                    Margin="0,0,80,0">
                                <TextBlock Text="{Binding EmployeeCountInSelectedDepartment, StringFormat='Số lượng nhân viên: {0}'}"
                                           Foreground="#1967D2"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding SelectedDepartment.DanhSachNhanVien}"
                                  SelectedItem="{Binding SelectedEmployee}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="35"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEE"
                                  BorderThickness="0"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã nhân viên"
                                                    Binding="{Binding MaNhanVien}"
                                                    Width="120"/>

                                <DataGridTextColumn Header="Họ tên"
                                                    Binding="{Binding HoTen}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Địa chỉ"
                                                    Binding="{Binding DiaChi}"
                                                    Width="220"/>

                                <DataGridTextColumn Header="Phòng ban"
                                                    Binding="{Binding DataContext.SelectedDepartment.TenPhongBan, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- FORM + NÚT -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,20,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="5,5,15,5">
                                <TextBlock Text="Mã nhân viên"
                                           Foreground="#777"
                                           Margin="0,0,0,3"/>
                                <TextBox Text="{Binding EmployeeIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6"
                                         IsEnabled="{Binding IsEmployeeIdEnabled}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Phòng ban"
                                           Foreground="#777"
                                           Margin="0,0,0,3"/>
                                <ComboBox ItemsSource="{Binding Departments}"
                                          DisplayMemberPath="TenPhongBan"
                                          SelectedItem="{Binding SelectedDepartment}"
                                          IsEnabled="{Binding IsInputEnabled}"
                                          Padding="6"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="5,5,15,5">
                                <TextBlock Text="Họ tên"
                                           Foreground="#777"
                                           Margin="0,0,0,3"/>
                                <TextBox Text="{Binding FullNameInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6"
                                         IsEnabled="{Binding IsInputEnabled}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <TextBlock Text="Địa chỉ"
                                           Foreground="#777"
                                           Margin="0,0,0,3"/>
                                <TextBox Text="{Binding AddressInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6"
                                         IsEnabled="{Binding IsInputEnabled}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Height="160">
                            <TextBlock Text="Thao tác"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"
                                       Foreground="#555"/>

                            <Button Command="{Binding AddCommand}"
                                    Content="+ Thêm"
                                    Background="#1A73E8"
                                    Foreground="White"
                                    Margin="0,3"
                                    Padding="0,8"
                                    Height="32"/>

                            <Button Command="{Binding EditCommand}"
                                    Content="✎ Sửa"
                                    Margin="0,3"
                                    Padding="0,5"
                                    Background="White"
                                    Height="28"/>

                            <Button Command="{Binding SaveCommand}"
                                    Content="💾 Lưu"
                                    Margin="0,3"
                                    Padding="0,5"
                                    Background="White"/>

                            <Button Command="{Binding DeleteCommand}"
                                    Content="🗑 Xóa"
                                    Margin="0,3"
                                    Padding="0,5"
                                    Background="White"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>