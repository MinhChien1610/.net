<Window x:Class="Tuan_10.Views.bai2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_10.Views"
        mc:Ignorable="d"
        Title="Bai2_Menu"
        Width="1000"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- MENU -->
        <Menu DockPanel.Dock="Top"
              Background="White"
              Padding="5">

            <!-- HỆ THỐNG -->
            <MenuItem Header="Hệ thống">
                <MenuItem Header="Sao lưu"/>
                <MenuItem Header="Phục hồi"/>
                <Separator/>
                <MenuItem Header="Đăng xuất"/>
                <MenuItem Header="Thoát"/>
            </MenuItem>

            <!-- DANH MỤC -->
            <MenuItem Header="Danh mục">
                <MenuItem Header="Khoa"
                          Command="{Binding ShowKhoaCommand}"/>

                <MenuItem Header="Lớp"
                          Command="{Binding ShowLopCommand}"/>

                <MenuItem Header="Môn học"
                          Command="{Binding ShowMonHocCommand}"/>

                <MenuItem Header="Sinh viên"
                          Command="{Binding ShowSinhVienCommand}"/>
            </MenuItem>

            <!-- QUẢN LÝ ĐIỂM -->
            <MenuItem Header="Quản lý điểm">
                <MenuItem Header="Nhập điểm"
                          Command="{Binding ShowNhapDiemCommand}"/>

                <MenuItem Header="Xem điểm">
                    <MenuItem Header="Theo Sinh viên"
                              Command="{Binding ShowDiemSVCommand}"/>

                    <MenuItem Header="Theo Lớp"
                              Command="{Binding ShowDiemLopCommand}"/>
                </MenuItem>
            </MenuItem>

        </Menu>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom"
                   Height="30"
                   Background="#F0F0F0">

            <StatusBarItem>
                <TextBlock Text="Khoa CNTT - Trường ĐH Công Thương TP.HCM | Sẵn sàng"
                           FontSize="11"
                           Foreground="Gray"/>
            </StatusBarItem>

        </StatusBar>

        <!-- MAIN VIEW -->
        <Grid>
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>

    </DockPanel>
</Window>