<UserControl x:Class="Tuan_7.Views.UcLichSu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="780"
             d:DesignHeight="463"
             Background="#E6E8EA"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#2979FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20,14">
            <TextBlock Text="Lịch sử giao dịch"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"/>
        </Border>

        <!-- FILTER -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tài khoản" Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding DanhSachTaiKhoan}"
                              SelectedItem="{Binding TaiKhoanDuocChon, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Loại giao dịch" Style="{StaticResource LabelStyle}"/>
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding DanhSachLoaiGiaoDich}"
                              SelectedItem="{Binding LoaiGiaoDichDuocChon, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Từ khóa" Style="{StaticResource LabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding TuKhoa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="Lọc"
                            Margin="0,0,10,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LocCommand}"/>

                    <Button Content="Hiển thị tất cả"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding HienThiTatCaCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABLE + SUMMARY -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding DanhSachGiaoDich}"
                          SelectedItem="{Binding GiaoDichDuocChon, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          Background="Transparent"
                          BorderThickness="1"
                          BorderBrush="#DCDDE1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0"
                          RowHeight="36"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã GD" Width="80" Binding="{Binding MaGD}"/>
                        <DataGridTextColumn Header="Ngày" Width="120" Binding="{Binding Ngay}"/>
                        <DataGridTextColumn Header="Loại" Width="110" Binding="{Binding Loai}"/>
                        <DataGridTextColumn Header="TK Nguồn" Width="*" Binding="{Binding TKNguon}"/>
                        <DataGridTextColumn Header="TK Đích" Width="*" Binding="{Binding TKDich}"/>
                        <DataGridTextColumn Header="Số tiền" Width="110" Binding="{Binding SoTien}"/>
                        <DataGridTextColumn Header="Nội dung" Width="1.5*" Binding="{Binding NoiDung}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        CornerRadius="12"
                        Padding="14">
                    <UniformGrid Columns="3">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Tổng thu"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TongThu}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#2E7D32"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Tổng chi"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TongChi}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#C62828"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Số giao dịch"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SoGiaoDich}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>