<Window x:Class="Tuan_4.bai_3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_4"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="bai_3" Height="570" Width="1000">

    <DockPanel>

        <Menu DockPanel.Dock="Top"
              FontFamily="Times New Roman"
              FontSize="16">

            <MenuItem Header="Hệ thống">
                <MenuItem Header="Đăng nhập"/>
                <MenuItem Header="Đổi mật khẩu"/>
                <MenuItem Header="Thoát"/>
            </MenuItem>

            <MenuItem Header="Danh mục">
                <MenuItem Header="Sinh viên"
                          Click="MenuClick_sinhvien"/>
                <MenuItem Header="Lớp học"
                          Click="MenuClick_lophoc"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">

            <ToolBar FontFamily="Times New Roman"
                     FontSize="16">

                <Button Content="➕ Thêm"
                        ToolTip="Thêm sinh viên"
                        Click="btnClick_luu"/>

                <Button Content="✖ Xóa"
                        ToolTip="Xóa sinh viên"
                        Click="btnClick_xoa"
                        IsEnabled="False"/>

                <Button Content="🚪 Thoát"
                        ToolTip="Thoát chương trình"
                        Click="btnClick_thoat"/>

            </ToolBar>

        </ToolBarTray>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"></ColumnDefinition>
                <ColumnDefinition Width="13*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TreeView Grid.Column="0"
                      Margin="10,10,10,10"
                      FontFamily="Times New Roman"
                      FontSize="16"
                      x:Name="treeSinhVien"
                      SelectedItemChanged="treeSinhVien_SelectedItemChanged">
            </TreeView>

            <Border Grid.Column="1"
                    Margin="10,10,10,10"
                    CornerRadius="6"
                    BorderBrush="Gray"
                    BorderThickness="1">

                <ContentControl x:Name="MainContent"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                Margin="5">
                    <local:ucLopHoc></local:ucLopHoc>

                </ContentControl>

            </Border>

        </Grid>

    </DockPanel>
</Window>
