<UserControl x:Class="Tuan_7.Views.UcLapHoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="960"
             Background="#F4F6F8"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Lập hóa đơn"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Quản lý bán hàng - Cafe Sinh Viên"
                               Margin="0,4,0,0"
                               Foreground="#64748B"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <DatePicker Width="150"
                                Height="38"
                                Margin="0,0,12,0"
                                SelectedDate="{Binding NgayLap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Content="+ Hóa đơn mới"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding HoaDonMoiCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- customer info -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Thông tin khách hàng"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Tên khách hàng"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding TenKhachHang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Số điện thoại"
                                   Margin="0,12,0,6"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SoDienThoai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <CheckBox Content="Là sinh viên (giảm 20%)"
                                  Margin="0,14,0,0"
                                  IsChecked="{Binding LaSinhVien, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- table selection -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Chọn bàn"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <UniformGrid Columns="2" Rows="2" Margin="0,4,0,0">
                            <RadioButton Content="Bàn 01"
                                         GroupName="Ban"
                                         Margin="0,6"
                                         IsChecked="{Binding IsBan01, Mode=TwoWay}"/>
                            <RadioButton Content="Bàn 02"
                                         GroupName="Ban"
                                         Margin="0,6"
                                         IsChecked="{Binding IsBan02, Mode=TwoWay}"/>
                            <RadioButton Content="Bàn 03"
                                         GroupName="Ban"
                                         Margin="0,6"
                                         IsChecked="{Binding IsBan03, Mode=TwoWay}"/>
                            <RadioButton Content="Bàn 04"
                                         GroupName="Ban"
                                         Margin="0,6"
                                         IsChecked="{Binding IsBan04, Mode=TwoWay}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CENTER -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- drinks -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Chọn món menu (có sẵn)"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Nước uống"
                                   FontWeight="Bold"
                                   Foreground="#334155"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="3">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Cafe đen" IsChecked="{Binding ChonCafeDen, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="20.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongCafeDen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Cafe đá" IsChecked="{Binding ChonCafeDa, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="25.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongCafeDa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Cafe sữa" IsChecked="{Binding ChonCafeSua, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="25.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongCafeSua, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Cafe sữa đá" IsChecked="{Binding ChonCafeSuaDa, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="30.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongCafeSuaDa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Cafe kem" IsChecked="{Binding ChonCafeKem, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="30.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongCafeKem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- foods -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Thức ăn"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="3">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Bánh mì trứng" IsChecked="{Binding ChonBanhMiTrung, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="15.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongBanhMiTrung, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Bánh mì cá" IsChecked="{Binding ChonBanhMiCa, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="15.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongBanhMiCa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Mỳ tôm trứng" IsChecked="{Binding ChonMyTomTrung, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="20.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongMyTomTrung, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Mỳ xào bò" IsChecked="{Binding ChonMyXaoBo, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="30.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongMyXaoBo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Mỳ cay bò" IsChecked="{Binding ChonMyCayBo, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Text="50.000đ" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource InputTextBoxStyle}" Height="32"
                                             Text="{Binding SoLuongMyCayBo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- RIGHT -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- receipt header -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="CAFE SINH VIÊN"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                        <TextBlock Text="HÓA ĐƠN THANH TOÁN"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"
                                   FontSize="11"
                                   Foreground="#64748B"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0">
                            <TextBlock Text="Mã HĐ: " Foreground="#64748B" FontSize="11"/>
                            <TextBlock Text="{Binding MaHoaDon}" Foreground="#334155" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- receipt info -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Thông tin hóa đơn"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Tên khách hàng:" Width="110"/>
                                <TextBlock Text="{Binding TenKhachHang}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Số điện thoại:" Width="110"/>
                                <TextBlock Text="{Binding SoDienThoai}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Bàn số:" Width="110"/>
                                <TextBlock Text="{Binding BanDangChon}"/>
                            </StackPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="4"
                                  ItemsSource="{Binding DanhSachMonDaChon}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên món" Binding="{Binding TenMon}" Width="*"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="45"/>
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia}" Width="70"/>
                                <DataGridTextColumn Header="T.Tiền" Binding="{Binding ThanhTien}" Width="75"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="Thanh toán"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Tạm tính" Width="110"/>
                                <TextBlock Text="{Binding TamTinhText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Giảm giá" Width="110"/>
                                <TextBlock Text="{Binding GiamGiaText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tổng thanh toán" Width="110" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TongThanhToanText}" FontWeight="Bold" Foreground="#2563EB"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- action buttons -->
                <StackPanel Grid.Row="4">
                    <Button Content="Tính tiền"
                            Margin="0,0,0,10"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding TinhTienCommand}"/>

                    <Button Content="Nhập lại"
                            Margin="0,0,0,10"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding NhapLaiCommand}"/>

                    <Button Content="Thanh toán"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ThanhToanCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>