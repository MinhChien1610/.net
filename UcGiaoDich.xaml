<UserControl x:Class="Tuan_7.Views.UcGiaoDich"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Background="#F8FAFC"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Thực hiện giao dịch"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="Gửi tiền, rút tiền hoặc chuyển khoản"
                               Margin="0,6,0,0"
                               Foreground="#64748B"
                               FontSize="13"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock Text="Loại giao dịch"
                                   Style="{StaticResource SectionLabelStyle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton Content="Gửi tiền"
                                         GroupName="LoaiGiaoDich"
                                         Margin="0,0,18,0"
                                         IsChecked="{Binding IsGuiTien, Mode=TwoWay}"/>

                            <RadioButton Content="Rút tiền"
                                         GroupName="LoaiGiaoDich"
                                         Margin="0,0,18,0"
                                         IsChecked="{Binding IsRutTien, Mode=TwoWay}"/>

                            <RadioButton Content="Chuyển khoản"
                                         GroupName="LoaiGiaoDich"
                                         IsChecked="{Binding IsChuyenKhoan, Mode=TwoWay}"/>
                        </StackPanel>

                        <TextBlock Text="Tài khoản nguồn"
                                   Style="{StaticResource SectionLabelStyle}"/>

                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  ItemsSource="{Binding DanhSachTaiKhoan}"
                                  SelectedItem="{Binding TaiKhoanNguon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{Binding SoDuHienTaiText}"
                                   Margin="0,8,0,0"
                                   FontStyle="Italic"
                                   Foreground="#64748B"/>

                        <TextBlock Text="Tài khoản đích"
                                   Style="{StaticResource SectionLabelStyle}"/>

                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  ItemsSource="{Binding DanhSachTaiKhoan}"
                                  SelectedItem="{Binding TaiKhoanDich, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Số tiền giao dịch"
                                   Style="{StaticResource SectionLabelStyle}"/>

                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SoTien, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Nội dung"
                                   Style="{StaticResource SectionLabelStyle}"/>

                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding NoiDung, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Xác nhận giao dịch"
                                Margin="0,18,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding XacNhanGiaoDichCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- RIGHT -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Tóm tắt"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>

                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        CornerRadius="14"
                        Padding="16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Loại giao dịch"
                                   Foreground="#64748B"/>
                        <TextBlock Text="{Binding LoaiGiaoDichText}"
                                   Style="{StaticResource SummaryValueStyle}"
                                   Margin="0,4,0,10"/>

                        <TextBlock Text="Số tiền"
                                   Foreground="#64748B"/>
                        <TextBlock Text="{Binding SoTienText}"
                                   Style="{StaticResource SummaryValueStyle}"
                                   Margin="0,4,0,10"/>

                        <TextBlock Text="Phí giao dịch"
                                   Foreground="#64748B"/>
                        <TextBlock Text="{Binding PhiGiaoDichText}"
                                   Style="{StaticResource SummaryValueStyle}"
                                   Margin="0,4,0,10"/>

                        <Separator Margin="0,8,0,12"/>

                        <TextBlock Text="Số dư sau giao dịch"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="#1E293B"/>

                        <TextBlock Text="{Binding SoDuSauGiaoDichText}"
                                   Margin="0,8,0,0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>