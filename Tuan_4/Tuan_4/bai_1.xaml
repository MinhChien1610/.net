<Window x:Class="Tuan_4.bai_1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_4"
        mc:Ignorable="d"
        Title="bai_1" Height="450" Width="800">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Hệ thống"
                      FontSize="16"
                      FontWeight="Bold"
                      FontFamily="Times New Roman"
                      Foreground="Blue">

                <MenuItem Header="Đăng nhập"/>
                <MenuItem Header="Thoát"/>
            </MenuItem>

            <MenuItem Header="Danh mục"
                      FontSize="16"
                      FontWeight="Bold"
                      FontFamily="Times New Roman"
                      Foreground="Blue">


                <MenuItem Header="Nhân viên"
                          Click="MenuClick_Nhanvien"/>
                <MenuItem Header="Phòng ban"
                          Click="MenuClick_Phongban"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            
            <ToolBar FontFamily="Times New Roman"
             FontSize="16">

                <Button Content="➕ Thêm"
                        ToolTip="Thêm nhân viên"/>

                <Button Content="✖ Xóa"
                        ToolTip="Xóa nhân viên"/>

                <Separator/>

                <Button Content="⎋ Thoát"
                        ToolTip="Thoát chương trình"/>

            </ToolBar>
        </ToolBarTray>

        <ContentControl x:Name="MainContent"
                        Margin="10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <local:ucNhanVien></local:ucNhanVien>
        </ContentControl>
        
    </DockPanel>
</Window>
