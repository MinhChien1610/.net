<Window x:Class="Tuan_4.bai_2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_4"
        mc:Ignorable="d"
        Title="bai_2" Height="550" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Mã phòng"
                       FontFamily="Times New Roman"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="30,20,0,0"/>

            <TextBlock Grid.Row="2"
                       Text="Tên phòng ban"
                       FontFamily="Times New Roman"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="30,10,0,0"/>

            <TextBox Grid.Row="1" 
                     Margin="30,5,20,0"
                     Height="35"
                     x:Name="txt_maphong"/>

            <TextBox Grid.Row="3" 
                     Margin="30,5,20,0"
                     Height="35"
                     x:Name="txt_tenphong"/>

            <Button Grid.Row="4"
                    Content="Thêm phòng ban"
                    FontFamily="Times New Roman"
                    FontSize="16"
                    Margin="30,20,20,0"
                    Height="35"
                    Click="btnClick_themphong"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="105*"></RowDefinition>
                <RowDefinition Height="73*"></RowDefinition>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0"
                      Header="Danh mục phòng ban"
                      BorderBrush="Black"
                      BorderThickness="1"
                      Margin="5,20,20,5"
                      FontFamily="Times New Roman"
                      FontSize="16">

                <TreeView x:Name="treePhongBan" Margin="5"
                          SelectedItemChanged="treePhongBan_SelectedItemChanged"/>

            </GroupBox>

            <GroupBox Grid.Row="1"
                      Header="THÔNG TIN PHÒNG BAN ĐANG CHỌN"
                      BorderBrush="Black"
                      BorderThickness="1"
                      Margin="5,5,20,20"
                      FontFamily="Times New Roman"
                      FontSize="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="116*"></ColumnDefinition>
                        <ColumnDefinition Width="297*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>


                    <TextBlock
                               Grid.Column="0"
                               Text="Phòng ban"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0" Height="18"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Mã phòng"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0" Height="19"/>

                    <TextBox Grid.Column="1"
                             Grid.Row="0" 
                             Margin="8,10,7,10"
                             Background="LightYellow"
                             x:Name="txt_phongbanchon"/>

                    <TextBox Grid.Column="1"
                             Grid.Row="1" 
                             Margin="8,10,7,10"
                             Background="LightYellow"
                             x:Name="txt_maphongchon"/>

                    <Button Grid.Column="1"
                            Grid.Row="2"
                            Content="Thoát"
                            Margin="178,10,7,10"
                            Click="btnThoat_Click"/>

                </Grid>

            </GroupBox>
            
        </Grid>

    </Grid>
</Window>
