<Window x:Class="Tuan_4.bai_4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tuan_4"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="bai_4" Height="700" Width="1000">

    <DockPanel>

        <Menu DockPanel.Dock="Top"
              FontFamily="Times New Roman"
              FontSize="16">

            <MenuItem Header="Hệ Thống">
                <MenuItem Header="Đổi mật khẩu"/>
                <MenuItem Header="Đăng xuất"/>
                <MenuItem Header="Thoát" Click="MenuClick_Thoat"/>
            </MenuItem>

            <MenuItem Header="Danh mục">
                <MenuItem Header="Nhân viên"/>
            </MenuItem>

            <MenuItem Header="Chấm công">
                <MenuItem Header="Chấm công"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="169*"/>
                <ColumnDefinition Width="331*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="Phòng ban"
                      FontFamily="Times New Roman"
                      FontSize="16"
                      BorderBrush="Gray"
                      BorderThickness="1"
                      Margin="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TreeView Grid.Row="0"
                              Height="400"
                              Margin="10"
                              x:Name="treephongban"
                              SelectedItemChanged="treephongban_SelectedItemChanged"/>

                    <TextBlock Grid.Row="1"
                               Text="Phòng ban"
                               Margin="10,7,5,0"/>

                    <TextBox Grid.Row="2"
                             Height="30"
                             Margin="10,10,10,0"
                             VerticalContentAlignment="Center"
                             x:Name="txt_themphongban"/>

                    <Button Grid.Row="3"
                            Content="Thêm phòng ban"
                            Height="40"
                            Margin="10,10,10,0"
                            Click="btnClick_ThemPhongBan"/>

                    <Button Grid.Row="4"
                            Content="Xóa phòng ban"
                            Height="40"
                            Margin="10"
                            Click="btnClick_XoaPhongBan"/>
                </Grid>
            </GroupBox>

            <ContentControl x:Name="MainContent"
                            Grid.Column="1"
                            Margin="10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
        </Grid>
    </DockPanel>
</Window>