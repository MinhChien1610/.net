<UserControl x:Class="Tuan_4.ucLopHoc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tuan_4"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <GroupBox Header="Thông tin lớp học"
                  FontFamily="Times New Roman"
                  FontSize="16"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  Margin="5">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" 
                           Grid.Column="0"
                           Text="Mã lớp"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>
                
                <TextBox Grid.Row="0" 
                         Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_malop"/>

                <TextBlock Grid.Row="1" 
                           Grid.Column="0"
                           Text="Tên lớp"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="1" 
                         Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_tenlop"/>

                <TextBlock Grid.Row="2" 
                           Grid.Column="0"
                           Text="Sĩ số"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="2" 
                         Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_siso"/>

                <TextBlock Grid.Row="3" 
                           Grid.Column="0"
                           Text="Giảng viên cố vấn"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="3" 
                         Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_giangvien"/>

                <StackPanel Grid.Row="4"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10,13,14,13">

                    <Button Content="Lưu"
                            Width="109"
                            Margin="0,0,20,0"
                            Click="btnClick_luu"/>

                    <Button Content="Xóa"
                            Width="109"
                            Margin="0,0,20,0"
                            Click="btnClick_xoa"/>

                    <Button Content="Làm mới"
                            Width="109"
                            Click="btnClick_lammoi"/>
                </StackPanel>


            </Grid>
                 
        </GroupBox>
    </Grid>
</UserControl>
