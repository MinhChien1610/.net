<UserControl x:Class="Tuan_4.UcSinhVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tuan_4"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="White">
        <GroupBox Header="Thông tin sinh viên"
                  FontFamily="Times New Roman"
                  FontSize="16"
                  BorderBrush="Gray"
                  BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Mã sinh viên"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_masinhvien"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Họ tên"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Margin="10,8,14,7"
                         x:Name="txt_hoten"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Ngày sinh"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <DatePicker Grid.Row="2" Grid.Column="1"
                            Margin="10,8,14,7"
                            VerticalContentAlignment="Center"
                            x:Name="dp_ngaysinh"/>

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Giới tính"
                           Margin="20,0,39,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="3"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10,8,14,7">
                    <RadioButton Content="Nam"
                                 GroupName="GioiTinh"
                                 Margin="0,0,30,0"
                                 VerticalAlignment="Center"
                                 x:Name="rb_nam"/>
                    <RadioButton Content="Nữ"
                                 GroupName="GioiTinh"
                                 VerticalAlignment="Center"
                                 x:Name="rb_nu"/>
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Sở thích"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="4"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10,8,14,7">
                    <CheckBox Content="Thể thao"
                              VerticalAlignment="Center"
                              Margin="0,0,30,0"
                              x:Name="cb_thethao"/>
                    
                    <CheckBox Content="Âm nhạc"
                              VerticalAlignment="Center"
                              Margin="0,0,30,0"
                              x:Name="cb_amnhac"/>
                    
                    <CheckBox Content="Du lịch"
                              VerticalAlignment="Center"
                              x:Name="cb_dulich"/>
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0"
                           Text="Lớp học"
                           Margin="20,20,0,20"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="1"
                          Grid.Row="5"
                          Margin="10,8,14,7"
                          x:Name="cbb_lophoc"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem>--Chọn lớp--</ComboBoxItem>
                    <ComboBoxItem>15DHTH01</ComboBoxItem>
                    <ComboBoxItem>15DHTH02</ComboBoxItem>
                    <ComboBoxItem>15DHTH03</ComboBoxItem>
                    <ComboBoxItem>15DHTH04</ComboBoxItem>
                    <ComboBoxItem>15DHTH05</ComboBoxItem>
                    <ComboBoxItem>15DHTH06</ComboBoxItem>
                    <ComboBoxItem>15DHTH07</ComboBoxItem>
                    <ComboBoxItem>15DHTH08</ComboBoxItem>
                    <ComboBoxItem>15DHTH09</ComboBoxItem>
                </ComboBox>

                <StackPanel Grid.Row="6"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10,13,14,13">

                    <Button Content="Lưu"
                            x:Name="btn_luu"
                            Width="109"
                            Margin="0,0,20,0"
                            Click="btnClick_luu"/>

                    <Button Content="Xóa"
                            x:Name="btn_xoa"
                            Width="109"
                            Margin="0,0,20,0"
                            Click="btnClick_xoa"/>

                    <Button Content="Thoát"
                            x:Name="btn_thoat"
                            Width="109"
                            Click="btnClick_thoat"/>
                    
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>