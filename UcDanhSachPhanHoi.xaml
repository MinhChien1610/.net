<UserControl x:Class="Tuan_7.Views.UcDanhSachPhanHoi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="484"
             d:DesignWidth="881"
             Background="#F1F5F9"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">


    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SmallCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="115"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="15">
        <Border Style="{StaticResource CardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="46"
                                Height="46"
                                CornerRadius="10"
                                Background="#E8F0FE">
                            <TextBlock Text="📊"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="15,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Danh sách phản hồi"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#1E293B"/>

                            <TextBlock Text="Tổng hợp phản hồi và thống kê nhanh"
                                       Margin="0,4,0,0"
                                       FontSize="13"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Làm mới"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LamMoiCommand}"/>
                </Grid>

                <!-- SUMMARY -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SmallCardStyle}"
                            Background="#EEF2FF">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="45"
                                    Height="45"
                                    CornerRadius="12"
                                    Background="#C7D2FE">
                                <TextBlock Text="📱"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Margin="15,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Tổng phản hồi"
                                           FontSize="13"
                                           Foreground="#4F46E5"/>
                                <TextBlock Text="{Binding TongPhanHoi}"
                                           Margin="0,6,0,0"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource SmallCardStyle}"
                            Background="#F0FDF4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="45"
                                    Height="45"
                                    CornerRadius="22.5"
                                    Background="#BBF7D0">
                                <TextBlock Text="★"
                                           FontSize="20"
                                           Foreground="#16A34A"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Margin="15,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Điểm trung bình"
                                           FontSize="13"
                                           Foreground="#16A34A"/>
                                <TextBlock Text="{Binding DiemTrungBinh}"
                                           Margin="0,6,0,0"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource SmallCardStyle}"
                            Background="#FFFBEB">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="45"
                                    Height="45"
                                    CornerRadius="12"
                                    Background="#FEF3C7">
                                <TextBlock Text="⚠"
                                           FontSize="18"
                                           Foreground="#D97706"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Margin="15,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Chưa xử lý"
                                           FontSize="13"
                                           Foreground="#D97706"/>
                                <TextBlock Text="{Binding ChuaXuLy}"
                                           Margin="0,6,0,0"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- DATAGRID -->
                <Border Grid.Row="4"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Background="White">
                    <DataGrid ItemsSource="{Binding DanhSachPhanHoi}"
                              SelectedItem="{Binding PhanHoiDuocChon, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              RowHeight="42"
                              AlternatingRowBackground="#FAFAFA"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              ColumnHeaderStyle="{StaticResource HeaderStyle}"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Width="60"
                                                Binding="{Binding Id}"/>

                            <DataGridTextColumn Header="Khách hàng"
                                                Width="*"
                                                Binding="{Binding TenKhachHang}"/>

                            <DataGridTextColumn Header="Ngày"
                                                Width="150"
                                                Binding="{Binding Ngay}"/>

                            <DataGridTextColumn Header="Điểm TB"
                                                Width="100"
                                                Binding="{Binding DiemTB}"/>

                            <DataGridTextColumn Header="Góp ý"
                                                Width="2*"
                                                Binding="{Binding GopY}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>