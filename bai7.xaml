<UserControl x:Class="Tuan_10.Views.bai7"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tuan_10.Views"
             mc:Ignorable="d"
             Width="900"
             Height="500"
             Background="White">

    <Grid Margin="15">

        <!-- Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== TITLE ===== -->
        <TextBlock Text="BẢNG ĐIỂM SINH VIÊN"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="DarkBlue"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15" />

        <!-- ===== SEARCH ===== -->
        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10"
                Background="White"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Mã sinh viên:"
                           VerticalAlignment="Center"
                           Margin="5,0" />

                <TextBox Grid.Column="1"
                         Height="25"
                         VerticalContentAlignment="Center"
                         Text="{Binding MaSVInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="2"
                        Content="Tìm"
                        Width="80"
                        Margin="10,0"
                        Command="{Binding SearchCommand}" />

                <TextBlock Grid.Column="3"
                           Text="Họ tên:"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="4"
                           Text="{Binding StudentName}"
                           Margin="10,0"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="5"
                           Text="Lớp:"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="6"
                           Text="{Binding ClassName}"
                           Margin="10,0"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ===== FILTER ===== -->
        <Border Grid.Row="2"
                Margin="0,0,0,10"
                Padding="10"
                Background="White"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Năm học:"
                           VerticalAlignment="Center"
                           Margin="5,0" />

                <ComboBox Width="180"
                          ItemsSource="{Binding ListNamHoc}"
                          SelectedItem="{Binding SelectedNamHoc}" />

                <TextBlock Text="Học kỳ:"
                           VerticalAlignment="Center"
                           Margin="25,0,5,0" />

                <ComboBox Width="150"
                          ItemsSource="{Binding ListHocKy}"
                          SelectedItem="{Binding SelectedHocKy}" />

                <Button Content="Xem bảng điểm"
                        Width="150"
                        Margin="50,0,0,0"
                        Command="{Binding ViewGradeCommand}" />

            </StackPanel>
        </Border>

        <!-- ===== DATA GRID ===== -->
        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ListDiem}"
                  IsReadOnly="True"
                  Background="White"
                  GridLinesVisibility="All"
                  BorderBrush="LightGray">

            <DataGrid.Columns>

                <DataGridTextColumn Header="STT"
                                    Binding="{Binding STT}"
                                    Width="50" />

                <DataGridTextColumn Header="Mã MH"
                                    Binding="{Binding MaMH}"
                                    Width="100" />

                <DataGridTextColumn Header="Tên môn học"
                                    Binding="{Binding TenMon}"
                                    Width="*" />

                <DataGridTextColumn Header="Số TC"
                                    Binding="{Binding SoTC}"
                                    Width="80" />

                <DataGridTextColumn Header="Điểm"
                                    Binding="{Binding DiemSo}"
                                    Width="80" />

                <DataGridTextColumn Header="Điểm chữ"
                                    Binding="{Binding DiemChu}"
                                    Width="100" />

            </DataGrid.Columns>

        </DataGrid>

        <!-- ===== SUMMARY ===== -->
        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Padding="10"
                Background="White"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">

            <UniformGrid Columns="3"
                         Width="500"
                         HorizontalAlignment="Right">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Tổng Tín chỉ:" FontWeight="Bold" />
                    <TextBlock Text="{Binding TongTinChi}" Margin="10,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="GPA:" FontWeight="Bold" />
                    <TextBlock Text="{Binding GPA}" Margin="10,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Xếp loại:" FontWeight="Bold" />
                    <TextBlock Text="{Binding XepLoai}" Margin="10,0" />
                </StackPanel>

            </UniformGrid>

        </Border>

    </Grid>
</UserControl>  