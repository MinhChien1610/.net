<UserControl x:Class="Tuan_7.Views.UcDanhSachHoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Tuan_7.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="957"
             d:DesignHeight="561"
             Background="#F1F5F9"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextBoxLikeDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Danh sách hóa đơn"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="Quản lý bán hàng - Cafe Sinh Viên"
                               Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="#64748B"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <DatePicker Style="{StaticResource TextBoxLikeDatePickerStyle}"
                                Margin="0,0,15,0"
                                SelectedDate="{Binding NgayChon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Content="+ Hóa đơn mới"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding TaoHoaDonMoiCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTER + SUMMARY -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Filter -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Bộ lọc hóa đơn"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,14"/>

                    <WrapPanel VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Từ ngày"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <DatePicker Style="{StaticResource TextBoxLikeDatePickerStyle}"
                                        SelectedDate="{Binding TuNgay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,10">
                            <TextBlock Text="Đến ngày"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <DatePicker Style="{StaticResource TextBoxLikeDatePickerStyle}"
                                        SelectedDate="{Binding DenNgay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                            <Button Content="Lọc"
                                    Width="90"
                                    Height="38"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding LocCommand}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thống kê nhanh"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding TongSoHoaDonText}"
                               Foreground="#64748B"
                               Margin="0,3"/>

                    <TextBlock Text="{Binding TongDoanhThuText}"
                               Foreground="#64748B"
                               Margin="0,3"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- DATAGRID -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="10">
            <DataGrid ItemsSource="{Binding DanhSachHoaDon}"
                      SelectedItem="{Binding HoaDonDuocChon, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      HeadersVisibility="Column"
                      RowHeight="42"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ"
                                        Binding="{Binding MaHoaDon}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Ngày giờ"
                                        Binding="{Binding NgayGio}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Khách hàng"
                                        Binding="{Binding TenKhachHang}"
                                        Width="*"/>

                    <DataGridTextColumn Header="SĐT"
                                        Binding="{Binding SoDienThoai}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Bàn"
                                        Binding="{Binding Ban}"
                                        Width="70"/>

                    <DataGridTextColumn Header="Tạm tính"
                                        Binding="{Binding TamTinh}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Giảm giá"
                                        Binding="{Binding GiamGia}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Thanh toán"
                                        Binding="{Binding ThanhToan}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>